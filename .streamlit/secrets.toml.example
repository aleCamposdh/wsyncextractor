# ──────────────────────────────────────────────────────────────
# Copia este archivo a secrets.toml y rellena los valores reales.
# El archivo secrets.toml NUNCA debe subirse a Git (ya está en .gitignore).
# En Streamlit Cloud, configura estas claves en Settings → Secrets.
# ──────────────────────────────────────────────────────────────

# Credenciales SupplyPro (ShineAndBright)
SUPPLYPRO_USERNAME = "programmer01"
SUPPLYPRO_PASSWORD = "TU_PASSWORD_AQUI"

# Jobber OAuth — obtener en https://developer.getjobber.com
JOBBER_CLIENT_ID     = "TU_CLIENT_ID_AQUI"
JOBBER_CLIENT_SECRET = "TU_CLIENT_SECRET_AQUI"

# URL pública del app (usada como redirect_uri en OAuth)
# Ejemplo: "https://worksyncextractor.streamlit.app/"
APP_URL = "https://worksyncextractor.streamlit.app/"
